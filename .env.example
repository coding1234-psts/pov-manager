# Copy to `.env` and fill in. Do not commit `.env`.
# Docker Compose reads this file for ${VAR} substitution in docker-compose.yml.

# --- Postgres (compose + Django DATABASE_URL on host) ---
POSTGRES_USER=povuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=povdb

# --- Mongo (compose init) ---
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_INITDB_DATABASE=pov_manager

# --- Django (see blank.env for full list) ---
DEBUG=True
SECRET_KEY=change-me-long-random
DATABASE_URL=postgresql://povuser:change-me@127.0.0.1:5432/povdb
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASSWORD=change-me
MONGO_DB_NAME=pov_manager
MICROSOFT_AUTH_ENABLED=False
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
MICROSOFT_AUTH_TENANT_ID=
XDR_DEFAULT_REGION=delta
VDR_ACCESS_TOKEN=
VDR_TEAM_ID=
CTU_ACCESS_TOKEN=
CTU_REPORTS_PATH=/ctu-reports
CTU_BASE_URL=
DMARC_LAMBDA_FUNCTION_NAME=local-dmarc-not-configured
DMARC_LAMBDA_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
